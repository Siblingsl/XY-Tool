# 研究系统海外部署环境变量（复制为 .env，勿提交）

# 镜像（CD 推送后）：ghcr.io/<owner>/xy-tool-research-api:latest
RESEARCH_IMAGE=ghcr.io/siblingsl/xy-tool-research-api:latest
API_HOST_PORT=8080

DB_USER=research
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=research

JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_RANDOM

# 前端 CF 域名（逗号分隔可加本地）
CORS_ORIGIN=https://emailanalysis.skyed.dpdns.org

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 必须与 Google 控制台「已获授权的重定向 URI」一致
GOOGLE_REDIRECT_URI=https://research-api.skyed.dpdns.org/api/research/gmail/callback
# 海外直连 Google 可留空
GOOGLE_PROXY_URL=
GOOGLE_PROXY_KEY=

RESEARCH_FRONTEND_URL=https://emailanalysis.skyed.dpdns.org
