# Server
PORT=8080

# Database (use DATABASE_URL or individual fields)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=research
DB_SSLMODE=disable

# Auth
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:5174,http://localhost:5173

# Google OAuth / Gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/research/gmail/callback
GOOGLE_PROXY_URL=
GOOGLE_PROXY_KEY=

# Frontend redirect after Gmail OAuth
RESEARCH_FRONTEND_URL=http://localhost:5174

# Optional: encrypt Gmail refresh tokens at rest (MVP stores plaintext)
RESEARCH_TOKEN_KEY=
