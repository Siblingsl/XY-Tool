# ============================================================
# 闲鱼自动发货工具 - 环境变量模板
# 复制为 .env 并填写真实值
# ============================================================

# ---- 运行环境 ----
NODE_ENV=development
PORT=3000

# ---- 数据库 (PostgreSQL) ----
DB_HOST=postgres
DB_PORT=5433
DB_USERNAME=xianyu
DB_PASSWORD=xianyu_dev_password
DB_DATABASE=xianyu_autodeliver
DB_SYNC=true          # 开发环境自动建表，生产请设为 false 并用 migration
# 生产部署：DB_SYNC=false + DB_MIGRATIONS_RUN=true，启动时自动执行未运行的 migration
# 开发默认 false（用 sync 建表），生产默认 true；显式设置以覆盖
DB_MIGRATIONS_RUN=false

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# Redis DB 索引（Bull 队列与自动回复上下文共用，默认 0）
REDIS_DB=0

# ---- JWT ----
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
# Refresh Token（无感续期，默认 30 天；不填则派生自 JWT_SECRET）
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ---- 账号 Cookie 加密主密钥 (AES-256-GCM, 32 字节 hex) ----
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_ENCRYPTION_KEY=replace_with_64_char_hex_string

# ---- 闲鱼签名服务 ----
# mock:    开发用假签名
# goofish: 使用 server/src/goofish/goofish-sdk.js（真实闲鱼 PC 协议，推荐）
# http:    第三方签名 API
# native:  自研 so 签名服务
SIGN_PROVIDER=goofish
SIGN_HTTP_URL=
SIGN_HTTP_TOKEN=
SIGN_NATIVE_ENDPOINT=http://127.0.0.1:9090

# ---- 订单监听 ----
# 主路径：IM WebSocket 付款消息建单（不易风控，推荐）
IM_PAYMENT_LISTEN_ENABLED=true
# 主建单：mtop 轮询待发货（默认 1 分钟）
ORDER_POLL_ENABLED=true
ORDER_POLL_INTERVAL_MS=60000
# true=Mock假订单
ORDER_MOCK_MODE=false

# IM 发卡密后是否调用闲鱼「确认发货」API（虚拟商品可选）
CONFIRM_DELIVERY_ENABLED=false

# Cookie 主动健康检查（会打 login.token，易滑块；WS 运行中可不需要）
COOKIE_HEALTH_CHECK_ENABLED=false
COOKIE_HEALTH_CHECK_INTERVAL_MS=600000

# Cookie 长登录保活（定时调 hasLogin.do 刷新核心登录态，解决扫码一天就过期）
# 仅 SIGN_PROVIDER=goofish 时生效，默认每 6 小时执行一次
COOKIE_RENEW_ENABLED=true
COOKIE_RENEW_CRON=0 */6 * * *

# ---- CORS ----
CORS_ORIGIN=http://localhost:5173

# ---- 限流（防爆破，毫秒窗口 + 最大请求数）----
# 全局默认；登录/注册接口在 Controller 上单独收紧为每分钟 5 次
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# ---- 激活码中台（对外验证 API 密钥）----
# 外部工具调 /api/license/verify 时用 X-API-Key 头鉴权
# 生成方式：openssl rand -hex 24
LICENSE_API_KEY=


# ============================================================
# ============================================================
# （研究系统 Gmail / 海外 Go API 配置见 research/deploy/.env.example）
# ============================================================

# ---- 风控建议 ----
# 1. 自动发货优先 IM_PAYMENT_LISTEN_ENABLED=true，ORDER_POLL_ENABLED=false
# 2. CONFIRM_DELIVERY_ENABLED 非必要不要开
# 3. 发货规则 delaySeconds 建议 3~30 秒，避免秒发
# 4. 同账号请勿多开实例并发 WS/发 IM
# 5. 漏单再临时 ORDER_POLL_ENABLED=true + 大间隔
