# ============================================================
# 闲鱼自动发货工具 - 生产环境变量模板
#
# 复制为 .env.prod 并填写真实值。.env.prod 不入 Git。
# 放在服务器 /opt/xianyu-tool/.env.prod
# ============================================================

# ---------- 镜像仓库（必填）----------
# GHCR 镜像所有者和仓库名（决定 docker-compose.prod.yml 拉取哪个镜像）
# 例如 GitHub 仓库 https://github.com/yourname/xianyu-tool
#   IMAGE_OWNER=yourname
#   IMAGE_REPO=xianyu-tool
# 注意：GHCR 镜像名一律小写，填大写也会被 deploy 脚本自动转小写
IMAGE_OWNER=your_github_username
IMAGE_REPO=xianyu-tool

# ---------- 宿主机端口（映射到容器 3000）----------
SERVER_HOST_PORT=14277

# ---------- 数据库（必填改密码）----------
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=xianyu
# ⚠️ 生产必须改强密码，建议：openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_DATABASE=xianyu_autodeliver
# 生产关闭自动建表，用 migration
DB_SYNC=false
DB_MIGRATIONS_RUN=true

# ---------- Redis（必填改密码）----------
REDIS_HOST=redis
REDIS_PORT=6379
# ⚠️ 生产建议设密码：openssl rand -base64 16
REDIS_PASSWORD=CHANGE_ME_TO_REDIS_PASSWORD

# ---------- JWT（必填）----------
# ⚠️ 生产必须改：openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ---------- Cookie 加密密钥（必填）----------
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ 一旦设定不可更改，否则已加密的账号 Cookie 无法解密
COOKIE_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING

# ---------- 签名服务 ----------
# goofish: 真实闲鱼协议（推荐）；mock: 开发用
SIGN_PROVIDER=goofish

# ---------- 订单监听 ----------
ORDER_POLL_INTERVAL_MS=15000
ORDER_MOCK_MODE=false
IM_PAYMENT_LISTEN_ENABLED=true

# ---------- Cookie 保活 ----------
COOKIE_RENEW_ENABLED=true
COOKIE_RENEW_CRON="0 */6 * * *"

# ---------- CORS ----------
# 前端在 Cloudflare Pages 时，填 CF 域名（如 https://xy-tool-web.pages.dev）
CORS_ORIGIN=https://your-app.pages.dev

# ---------- Cloudflare Tunnel（国内服务器推荐，免备案）----------
# 在 CF Zero Trust 创建 Tunnel 后填入 Token；详见 scripts/setup-cloudflare-tunnel.sh
# CLOUDFLARE_TUNNEL_TOKEN=
# 配好后 GitHub Variable BACKEND_URL 改为 https://api.你的域名（走隧道 HTTPS，不要写 IP:端口）

# ---------- 限流 ----------
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# ---------- 告警（可选）----------
ALERT_ENABLED=false
ALERT_DINGTALK_WEBHOOK=
ALERT_DINGTALK_SECRET=
ALERT_WECHAT_WEBHOOK=
